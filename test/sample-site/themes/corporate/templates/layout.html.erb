<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= defined?(@page_title) && @page_title ? "#{@page_title} | #{@config["title"]}" : @config["title"] %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= @config["description"] %>">
  <% if @config["google_webmaster_tools"] -%>
  <meta name="google-site-verification" content="<%= @config["google_webmaster_tools"] %>">
  <% end -%>
  <link rel="alternate" type="application/atom+xml" href="/feed.atom" title="<%= @config["title"] %> Feed">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/static/css/theme.css" rel="stylesheet">
</head>
<body>
  <!-- TOP NAV -->
  <div id="top-nav" class="wrapper">
    <div class="container-fluid content-strip">
      <header>
        <p id="blog-title">
          <a href="/" class="subtle"><%= @config["title"] %></a>
        </p>
      </header>
    </div>
  </div>

  <!-- HEADER -->
  <div id="header" class="wrapper">
    <div class="container-fluid content-strip">
      <nav>
        <a href="/">Blog</a>
        <% Array(@pages).each do |p| -%>
        <a href="<%= p.permalink %>"><%= p.title %></a>
        <% end -%>
        <a href="/archives/">Archives</a>
      </nav>
    </div>
  </div>

  <!-- CONTENT -->
  <div id="content" class="wrapper">
    <div class="container-fluid content-strip">
      <div class="row-fluid">
        <div class="span8">
          <div class="articles">
            <%= yield_content %>
          </div>
        </div>

        <!-- SIDEBAR -->
        <div id="sidebar" class="span3 offset1 small">
          <% if @config["description"] && !@config["description"].empty? -%>
          <h3 class="first">About</h3>
          <p><%= @config["description"] %></p>
          <% end -%>

          <h3>Follow</h3>
          <ul>
            <% if @config["twitter"] -%>
            <li>
              <span class="icon">t</span>
              <a href="https://twitter.com/<%= @config["twitter"] %>">@<%= @config["twitter"] %> on Twitter</a>
            </li>
            <% end -%>
            <li>
              <span class="icon">r</span>
              <a href="/feed.atom">Atom Feed</a>
            </li>
          </ul>

          <% if @categories && !@categories.empty? -%>
          <h3>Categories</h3>
          <ul>
            <% @categories.sort.each do |cat_name, cat_articles| -%>
            <li>
              <a href="/<%= cat_name %>/">
                <%= cat_name.gsub("-", " ").split.map(&:capitalize).join(" ") %>
                (<%= cat_articles.size %>)
              </a>
            </li>
            <% end -%>
          </ul>
          <% end -%>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <div id="footer" class="wrapper">
    <div class="container-fluid content-strip">
      <footer class="row-fluid">
        <p>&copy; <%= Time.now.year %> <%= @config["author"] %> &bull;
          Powered by <a class="subtle" href="https://github.com/nbuggia/tika">Tika</a></p>
      </footer>
    </div>
  </div>

  <% if @config["google_analytics_id"] -%>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= @config["google_analytics_id"] %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= @config["google_analytics_id"] %>');
  </script>
  <% end -%>
</body>
</html>
