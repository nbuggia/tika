<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= defined?(@page_title) && @page_title ? "#{@page_title} | #{@config["title"]}" : @config["title"] %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= @config["description"] %>">
  <% if @config["google_webmaster_tools"] -%>
  <meta name="google-site-verification" content="<%= @config["google_webmaster_tools"] %>">
  <% end -%>
  <link rel="alternate" type="application/atom+xml" href="/feed.atom" title="<%= @config["title"] %> Feed">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/static/css/theme.css" rel="stylesheet">
</head>
<body>
  <!-- HEADER -->
  <div id="header" class="wrapper bluebg">
    <div class="container-fluid content-strip">
      <header>
        <p id="blog-title"><a href="/" class="blog-title nav"><%= @config["title"] %></a></p>
      </header>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div id="content" class="wrapper bluebg">
    <div class="container-fluid content-strip">
      <div class="row-fluid">
        <div class="posts">
          <%= yield_content %>
        </div>
      </div>
    </div>
  </div>

  <!-- NAVIGATION -->
  <div id="navigation" class="wrapper bluebg">
    <div class="container-fluid content-strip">
      <div class="row-fluid">
        <div class="span3">
          <h4>Pages</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <% Array(@pages).each do |p| -%>
            <li><a href="<%= p.permalink %>"><%= p.title %></a></li>
            <% end -%>
            <li><a href="/archives/">Archives</a></li>
          </ul>
        </div>

        <% if @categories && !@categories.empty? -%>
        <div class="span3">
          <h4>Categories</h4>
          <ul>
            <% @categories.sort.each do |cat_name, cat_articles| -%>
            <li><a href="/<%= cat_name %>/">
              <%= cat_name.gsub("-", " ").split.map(&:capitalize).join(" ") %>
              (<%= cat_articles.size %>)
            </a></li>
            <% end -%>
          </ul>
        </div>
        <% end -%>

        <% if @config["twitter"] -%>
        <div class="span3">
          <ul>
            <li><a href="https://twitter.com/<%= @config["twitter"] %>">Twitter</a></li>
          </ul>
        </div>
        <% end -%>

        <div class="span3">
          <ul>
            <li><a href="/feed.atom">Atom Feed</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <div id="footer" class="wrapper bluebg">
    <div class="container-fluid content-strip">
      <footer class="row-fluid">
        <p>&copy; <%= Time.now.year %> <%= @config["author"] %> &bull;
          Powered by <a class="nav" href="https://github.com/nbuggia/tika">Tika</a></p>
      </footer>
    </div>
  </div>

  <% if @config["google_analytics_id"] -%>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= @config["google_analytics_id"] %>"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '<%= @config["google_analytics_id"] %>');
  </script>
  <% end -%>
</body>
</html>
